#!/bin/sh

CONFIG=${WAN_SPLIT_CONFIG:-/etc/wan-split.conf}

[ -r "$CONFIG" ] && . "$CONFIG"

ENABLED=${ENABLED:-0}
INTERFACES=${INTERFACES:-"tethering modem_2_1 wan secondwan wwan"}
PRIO=${PRIO:-25300}
TABLE_BASE=${TABLE_BASE:-20010}
ASSIGNMENT_MODE=${ASSIGNMENT_MODE:-balanced}
HEALTH_CHECK=${HEALTH_CHECK:-1}
HEALTH_TARGETS=${HEALTH_TARGETS:-"1.1.1.1 8.8.8.8"}
HEALTH_COUNT=${HEALTH_COUNT:-1}
HEALTH_TIMEOUT=${HEALTH_TIMEOUT:-2}
HOTPLUG_REBALANCE=${HOTPLUG_REBALANCE:-1}
EXCLUDE_IPS=${EXCLUDE_IPS:-}
LEASE_FILE=${LEASE_FILE:-/tmp/dhcp.leases}
STATE_DIR=${STATE_DIR:-/tmp/wan-split}
LOG_FILE=${LOG_FILE:-/tmp/wan-split.log}

STATE_FILE="$STATE_DIR/state"
ACTIVE_FILE="$STATE_DIR/active"
ASSIGN_FILE="$STATE_DIR/assignments"
LOCK_DIR="$STATE_DIR/lock"
RUNTIME_ENABLED_FILE="$STATE_DIR/enabled"

if [ -f "$RUNTIME_ENABLED_FILE" ]; then
	ENABLED=1
else
	ENABLED=0
fi

usage() {
	cat <<'EOF'
Usage: wan-split COMMAND

Commands:
  dry-run      Show active WANs and planned client assignments; no route changes
  on           Enable and apply source-based client WAN splitting
  off          Disable and remove all wan-split routing rules/tables
  apply        Apply if ENABLED=1; otherwise no-op
  rebalance    Recompute and reinstall assignments immediately
  stop         Remove all wan-split routing rules/tables without editing config
  status       Show configuration, active WANs, assignments, and installed rules
  hotplug      Internal use by /etc/hotplug.d/iface/95-wan-split
EOF
}

log() {
	mkdir -p "$STATE_DIR"
	echo "$(date '+%Y-%m-%d %H:%M:%S') $*" >> "$LOG_FILE"
}

lock_acquire() {
	mkdir -p "$STATE_DIR"
	i=0
	while ! mkdir "$LOCK_DIR" 2>/dev/null; do
		i=$((i + 1))
		if [ "$i" -ge 20 ]; then
			echo "wan-split is busy; try again in a moment." >&2
			return 1
		fi
		sleep 1
	done
	trap 'lock_release' EXIT INT TERM
}

lock_release() {
	rm -rf "$LOCK_DIR" 2>/dev/null || true
	trap - EXIT INT TERM
}

set_enabled() {
	value="$1"
	mkdir -p "$STATE_DIR"
	if [ "$value" = "1" ]; then
		touch "$RUNTIME_ENABLED_FILE"
	else
		rm -f "$RUNTIME_ENABLED_FILE"
	fi

	# Keep persisted config disabled so reboot is always a safe exit.
	persist_value=0
	if [ -f "$CONFIG" ] && grep -q '^ENABLED=' "$CONFIG"; then
		tmp="${CONFIG}.tmp.$$"
		sed "s/^ENABLED=.*/ENABLED=$persist_value/" "$CONFIG" > "$tmp" && mv "$tmp" "$CONFIG"
	else
		echo "ENABLED=$persist_value" >> "$CONFIG"
	fi
	ENABLED="$value"
}

lan_dev() {
	ip -4 route show | awk '$1 ~ /^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+\/[0-9]+$/ && $3 == "br-lan" { print $3; exit }'
}

lan_cidr() {
	ip -4 route show dev br-lan scope link | awk '$1 ~ /^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+\/[0-9]+$/ { print $1; exit }'
}

lan_src() {
	ip -4 addr show dev br-lan | awk '/inet / { sub(/\/.*/, "", $2); print $2; exit }'
}

lan_prefix24() {
	lan_src | awk -F. 'NF == 4 { print $1 "." $2 "." $3 "." }'
}

table_for_iface() {
	want="$1"
	i=0
	for iface in $INTERFACES; do
		if [ "$iface" = "$want" ]; then
			echo $((TABLE_BASE + i))
			return 0
		fi
		i=$((i + 1))
	done
	return 1
}

iface_status_json() {
	ifstatus "$1" 2>/dev/null
}

wan_info() {
	iface="$1"
	json="$(iface_status_json "$iface")"
	[ -n "$json" ] || return 1

	up="$(echo "$json" | jsonfilter -q -e '@.up' 2>/dev/null)"
	[ "$up" = "true" ] || return 1

	dev="$(echo "$json" | jsonfilter -q -e '@.l3_device' 2>/dev/null)"
	[ -n "$dev" ] || dev="$(echo "$json" | jsonfilter -q -e '@.device' 2>/dev/null)"
	[ -n "$dev" ] || return 1

	route="$(ip -4 route show default dev "$dev" 2>/dev/null | head -n 1)"
	[ -n "$route" ] || return 1

	gw="$(echo "$route" | awk '{ for (i = 1; i <= NF; i++) if ($i == "via") { print $(i + 1); exit } }')"
	src="$(echo "$route" | awk '{ for (i = 1; i <= NF; i++) if ($i == "src") { print $(i + 1); exit } }')"
	metric="$(echo "$route" | awk '{ for (i = 1; i <= NF; i++) if ($i == "metric") { print $(i + 1); exit } }')"
	[ -n "$src" ] || src="$(ip -4 addr show dev "$dev" | awk '/inet / { sub(/\/.*/, "", $2); print $2; exit }')"
	table="$(table_for_iface "$iface")" || return 1

	wan_healthy "$dev" "$src" || return 1

	echo "$iface|$table|$dev|$gw|$src|$metric"
}

wan_healthy() {
	dev="$1"
	src="$2"

	[ "$HEALTH_CHECK" = "1" ] || return 0
	command -v ping >/dev/null 2>&1 || return 0

	for target in $HEALTH_TARGETS; do
		if [ -n "$src" ]; then
			ping -4 -I "$src" -c "$HEALTH_COUNT" -W "$HEALTH_TIMEOUT" "$target" >/dev/null 2>&1 && return 0
		else
			ping -4 -I "$dev" -c "$HEALTH_COUNT" -W "$HEALTH_TIMEOUT" "$target" >/dev/null 2>&1 && return 0
		fi
	done

	return 1
}

build_active_file() {
	out="$1"
	: > "$out"
	for iface in $INTERFACES; do
		wan_info "$iface" >> "$out"
	done
}

active_count() {
	file="$1"
	[ -f "$file" ] || { echo 0; return; }
	grep -c '|' "$file" 2>/dev/null
}

is_excluded_ip() {
	ip="$1"
	case " $EXCLUDE_IPS " in
		*" $ip "*) return 0 ;;
	esac
	return 1
}

score_pair() {
	mac="$1"
	iface="$2"
	if command -v sha256sum >/dev/null 2>&1; then
		printf '%s' "$mac|$iface" | sha256sum | awk '{ print $1 }'
	elif command -v md5sum >/dev/null 2>&1; then
		printf '%s' "$mac|$iface" | md5sum | awk '{ print $1 }'
	else
		printf '%s' "$mac|$iface" | hexdump -v -e '1/1 "%02x"'
	fi
}

choose_wan() {
	mac="$1"
	active="$2"
	best_iface=
	best_score=
	while IFS='|' read -r iface table dev gw src metric; do
		[ -n "$iface" ] || continue
		score="$(score_pair "$mac" "$iface")"
		if [ -z "$best_score" ] || [ "$score" \> "$best_score" ]; then
			best_score="$score"
			best_iface="$iface"
		fi
	done < "$active"
	echo "$best_iface"
}

active_nth() {
	active="$1"
	n="$2"
	awk -F'|' -v n="$n" 'NR == n { print; exit }' "$active"
}

line_for_iface() {
	iface="$1"
	active="$2"
	grep "^$iface|" "$active" | head -n 1
}

list_leases() {
	prefix="$(lan_prefix24)"
	[ -n "$prefix" ] || return 0
	[ -f "$LEASE_FILE" ] || return 0
	awk -v prefix="$prefix" '
		NF >= 3 && index($3, prefix) == 1 {
			host = (NF >= 4 ? $4 : "*")
			print $2 "|" $3 "|" host
		}
	' "$LEASE_FILE"
}

list_assignments() {
	active="$1"
	count="$(active_count "$active")"
	[ "$count" -gt 0 ] || return 0

	if [ "$ASSIGNMENT_MODE" = "balanced" ]; then
		idx=0
		list_leases | while IFS='|' read -r mac ip host; do
			[ -n "$mac" ] && [ -n "$ip" ] || continue
			is_excluded_ip "$ip" && continue
			key="$(score_pair "$mac" "lease")"
			echo "$key|$mac|$ip|$host"
		done | sort | while IFS='|' read -r key mac ip host; do
			wan_num=$((idx % count + 1))
			line="$(active_nth "$active" "$wan_num")"
			IFS='|' read -r iface table dev gw src metric <<EOF
$line
EOF
			echo "$ip|$mac|$host|$iface|$table|$dev|$gw|$src|$metric"
			idx=$((idx + 1))
		done
	else
		list_leases | while IFS='|' read -r mac ip host; do
			[ -n "$mac" ] && [ -n "$ip" ] || continue
			is_excluded_ip "$ip" && continue
			iface="$(choose_wan "$mac" "$active")"
			[ -n "$iface" ] || continue
			line="$(line_for_iface "$iface" "$active")"
			IFS='|' read -r _iface table dev gw src metric <<EOF
$line
EOF
			echo "$ip|$mac|$host|$iface|$table|$dev|$gw|$src|$metric"
		done
	fi
}

cleanup_routes() {
	mkdir -p "$STATE_DIR"

	if [ -f "$STATE_FILE" ]; then
		while read -r kind ip table prio iface rest; do
			[ "$kind" = "RULE" ] || continue
			ip rule del from "$ip/32" table "$table" priority "$prio" 2>/dev/null
		done < "$STATE_FILE"
	fi

	# Last-resort cleanup for stale rules if the state file was lost.
	while ip rule show | grep -q "^$PRIO:"; do
		ip rule del priority "$PRIO" 2>/dev/null || break
	done

	for iface in $INTERFACES; do
		table="$(table_for_iface "$iface")" || continue
		ip route flush table "$table" >/dev/null 2>&1
	done

	rm -f "$STATE_FILE" "$ASSIGN_FILE"
}

add_default_route() {
	table="$1"
	dev="$2"
	gw="$3"
	src="$4"

	if [ -n "$gw" ] && [ -n "$src" ]; then
		ip route add default via "$gw" dev "$dev" src "$src" table "$table"
	elif [ -n "$gw" ]; then
		ip route add default via "$gw" dev "$dev" table "$table"
	elif [ -n "$src" ]; then
		ip route add default dev "$dev" src "$src" table "$table"
	else
		ip route add default dev "$dev" table "$table"
	fi
}

install_routes() {
	active="$1"
	lan_net="$(lan_cidr)"
	lan_ip="$(lan_src)"
	lan_device=br-lan

	[ -n "$lan_net" ] || { echo "No LAN route found on br-lan" >&2; return 1; }
	[ -n "$lan_ip" ] || { echo "No LAN address found on br-lan" >&2; return 1; }

	: > "$STATE_FILE"
	: > "$ASSIGN_FILE"

	while IFS='|' read -r iface table dev gw src metric; do
		[ -n "$iface" ] || continue
		ip route flush table "$table" >/dev/null 2>&1
		ip route add "$lan_net" dev "$lan_device" scope link src "$lan_ip" table "$table" 2>/dev/null
		add_default_route "$table" "$dev" "$gw" "$src" || return 1
		echo "WAN $iface $table $dev $gw $src $metric" >> "$STATE_FILE"
	done < "$active"

	list_assignments "$active" | while IFS='|' read -r ip mac host iface table dev gw src metric; do
		[ -n "$ip" ] && [ -n "$iface" ] || continue
		ip rule add from "$ip/32" table "$table" priority "$PRIO" || return 1
		echo "RULE $ip $table $PRIO $iface $mac $host" >> "$STATE_FILE"
		echo "$ip $mac $host $iface $table $dev $gw $src" >> "$ASSIGN_FILE"
	done
}

plan() {
	active="$1"
	echo "Active WANs:"
	if [ "$(active_count "$active")" -eq 0 ]; then
		echo "  none"
	else
		while IFS='|' read -r iface table dev gw src metric; do
			[ -n "$iface" ] || continue
			echo "  $iface table=$table dev=$dev gw=${gw:-none} src=${src:-none} metric=${metric:-none}"
		done < "$active"
	fi

	echo "Planned assignments:"
	if [ "$(active_count "$active")" -eq 0 ]; then
		echo "  none"
		return
	fi
	leases="$(list_leases)"
	if [ -z "$leases" ]; then
		echo "  no current DHCP leases in LAN prefix"
		return
	fi
	list_assignments "$active" | while IFS='|' read -r ip mac host iface table dev gw src metric; do
		echo "  $ip $mac $host -> $iface table=$table dev=$dev"
	done
}

cmd_dry_run() {
	mkdir -p "$STATE_DIR"
	active_tmp="$STATE_DIR/active.dry-run.$$"
	trap 'rm -f "$active_tmp"' EXIT INT TERM
	build_active_file "$active_tmp"
	plan "$active_tmp"
	rm -f "$active_tmp"
	trap - EXIT INT TERM
}

cmd_apply_force() {
	mkdir -p "$STATE_DIR"
	lock_acquire || return 1
	active_tmp="$STATE_DIR/active.apply.$$"
	build_active_file "$active_tmp"

	count="$(active_count "$active_tmp")"
	if [ "$count" -lt 1 ]; then
		log "no active WANs; cleaning up"
		cleanup_routes
		echo "No active WANs found; removed wan-split routes."
		rm -f "$active_tmp"
		lock_release
		return 1
	fi

	cleanup_routes
	build_active_file "$active_tmp"
	install_routes "$active_tmp" || {
		echo "Install failed; cleaning up wan-split routes." >&2
		log "install failed; cleanup"
		cleanup_routes
		rm -f "$active_tmp"
		lock_release
		return 1
	}
	cp "$active_tmp" "$ACTIVE_FILE"
	log "applied with $(active_count "$active_tmp") active WAN(s)"
	plan "$active_tmp"
	rm -f "$active_tmp"
	lock_release
}

cmd_apply() {
	if [ "$ENABLED" != "1" ]; then
		echo "wan-split disabled; no route changes."
		return 0
	fi
	cmd_apply_force
}

cmd_status() {
	echo "wan-split status"
	echo "  enabled=$ENABLED"
	echo "  interfaces=$INTERFACES"
	echo "  priority=$PRIO"
	echo "  table_base=$TABLE_BASE"
	echo "  assignment_mode=$ASSIGNMENT_MODE"
	echo "  health_check=$HEALTH_CHECK targets=$HEALTH_TARGETS"
	echo "  lease_file=$LEASE_FILE"
	echo
	mkdir -p "$STATE_DIR"
	active_tmp="$STATE_DIR/active.status.$$"
	trap 'rm -f "$active_tmp"' EXIT INT TERM
	build_active_file "$active_tmp"
	plan "$active_tmp"
	rm -f "$active_tmp"
	trap - EXIT INT TERM
	echo
	echo "Installed wan-split rules:"
	ip rule show | grep "^$PRIO:" || echo "  none"
	echo
	echo "Current assignments:"
	if [ -f "$ASSIGN_FILE" ]; then
		sed 's/^/  /' "$ASSIGN_FILE"
	else
		echo "  none"
	fi
}

cmd_hotplug() {
	action="$1"
	iface="$2"
	[ "$ENABLED" = "1" ] || exit 0
	[ "$HOTPLUG_REBALANCE" = "1" ] || exit 0
	log "hotplug action=${action:-unknown} interface=${iface:-unknown}"
	cmd_apply_force >/dev/null 2>&1
}

case "$1" in
	dry-run)
		cmd_dry_run
		;;
	on|enable)
		set_enabled 1
		cmd_apply_force
		;;
	off|disable)
		lock_acquire || exit 1
		set_enabled 0
		cleanup_routes
		log "disabled"
		lock_release
		echo "wan-split disabled and routes removed."
		;;
	apply|start)
		cmd_apply
		;;
	rebalance)
		cmd_apply_force
		;;
	stop)
		lock_acquire || exit 1
		cleanup_routes
		log "stopped"
		lock_release
		echo "wan-split routes removed."
		;;
	status)
		cmd_status
		;;
	hotplug)
		cmd_hotplug "$2" "$3"
		;;
	help|-h|--help|"")
		usage
		;;
	*)
		echo "Unknown command: $1" >&2
		usage >&2
		exit 2
		;;
esac
